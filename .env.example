# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@your-cluster.mongodb.net/DATABASE?retryWrites=true&w=majority

# Optional dedicated Mongo URI for canonical microservice data (sites + site_connections in service-redaction)
# When empty, server falls back to MONGODB_URI.
SERVICE_REDACTION_MONGODB_URI=

# Region Lovers API (backend proxies /api/auth/login → {REGIONLOVERS_API_URL}/auth/login)
REGIONLOVERS_API_URL=https://api-prod.regionlovers.ai

# Optional: if the RL API requires an API key on requests
# RL_API_KEY=

# Server mode flag: must be "true" or "false" (do not use "production").
# When true, login may omit password and use ENVIRONMENT_MODE_DEV_PASSWORD instead.
ENVIRONMENT_MODE=false
ENVIRONMENT_MODE_DEV_PASSWORD=

# 32-byte hex (64 chars) or any string (hashed to 32 bytes) — encrypts WordPress application passwords at rest.
# If empty, passwords are stored in plaintext (dev only); generate with: openssl rand -hex 32
WP_CREDENTIALS_SECRET=

# Cache TTL (ms) for WordPress proxy responses in memory / 0 to disable. Client can bypass with ?refresh=1
WP_PROXY_CACHE_TTL_MS=300000

# Frontend: when true, login UI hides the Region Lovers password field (server must use ENVIRONMENT_MODE + DEV password)
VITE_ENVIRONMENT_MODE=false

# Frontend: optional absolute backend URL in production (e.g. https://my-backend.up.railway.app)
# When empty, frontend uses same-origin /api routes.
VITE_API_BASE_URL=

# Frontend: optional ingestion-service URL for direct sites/connections calls (e.g. https://ingestion-service.up.railway.app)
# When empty in local dev, defaults to http://localhost:4001
VITE_INGESTION_SERVICE_URL=
