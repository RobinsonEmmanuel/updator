# WordPress API Configuration
# Copy this file to .env.local and fill in your values

# Example for one site (you can add multiple)
VITE_WP_SITE_1_URL=https://example.com
VITE_WP_SITE_1_USERNAME=your_username
VITE_WP_SITE_1_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# To get an Application Password:
# 1. Go to WordPress Admin → Users → Your Profile
# 2. Scroll down to "Application Passwords"
# 3. Enter a name (e.g., "Actualisator") and click "Add New Application Password"
# 4. Copy the generated password (spaces are fine)
