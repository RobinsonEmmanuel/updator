{
  "name": "actualisation-sites",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently -k \"npm run server\" \"wait-on http://127.0.0.1:3001/api/health && npm run dev\"",
    "preview:all": "concurrently -k \"npm run server\" \"wait-on http://127.0.0.1:3001/api/health && npm run preview\"",
    "seed:sites": "tsx server/scripts/seedSites.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
